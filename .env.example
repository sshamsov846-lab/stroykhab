# Supabase (Vite reads VITE_*; NEXT_PUBLIC_* also supported)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Для npm run db:setup (создание таблиц) — один из вариантов:
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Telegram
VITE_BOT_USERNAME=your_bot_username

# Yandex Vision
VITE_YANDEX_API_KEY=your-yandex-key
VITE_YANDEX_FOLDER_ID=your-folder-id

# App
VITE_APP_NAME=СтройХаб
VITE_APP_VERSION=0.1.0
